<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MathGame.MainPage"
             BackgroundImageSource="math.jpg">

    <ContentView>
        <VerticalStackLayout Spacing="25" Padding="50">
            <Label Text="Math Game"
                   FontSize="48"
                   TextColor="Black"
                   HorizontalOptions="Center"
                   FontFamily="PressStartRegular" />
            <Label Text="Choose Game Mode:"
                   FontSize="32"
                   TextColor="Black"
                   HorizontalOptions="Center"
                   FontFamily="PressStartRegular" />
            <Grid Margin="0,100">
                <Grid RowDefinitions="*,*" ColumnDefinitions="*,*,*,*">
                    <Button Grid.Row="0" Grid.Column="0"
                            Text="Addition"
                            Margin="12"
                            Clicked="OnGameChosen"
                            FontFamily="PressStartRegular">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnPointerEntered"
                                                      PointerExited="OnPointerExited" />
                        </Button.GestureRecognizers>
                    </Button>
                    <Button Grid.Row="0" Grid.Column="1"
                            Text="Subtraction"
                            Margin="12"
                            Clicked="OnGameChosen"
                            FontFamily="PressStartRegular">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnPointerEntered"
                                                      PointerExited="OnPointerExited" />
                        </Button.GestureRecognizers>
                    </Button>
                    <Button Grid.Row="0" Grid.Column="2"
                            Text="Multiplication"
                            Margin="12"
                            Clicked="OnGameChosen"
                            FontFamily="PressStartRegular">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnPointerEntered"
                                                      PointerExited="OnPointerExited" />
                        </Button.GestureRecognizers>
                    </Button>
                    <Button Grid.Row="0" Grid.Column="3"
                            Text="Division"
                            Margin="12"
                            Clicked="OnGameChosen"
                            FontFamily="PressStartRegular">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnPointerEntered"
                                                      PointerExited="OnPointerExited" />
                        </Button.GestureRecognizers>
                    </Button>
                    <Button Grid.Row="1" Grid.ColumnSpan="4" Grid.Column="0"
                            BackgroundColor="DimGrey"
                            Text="View Previous Game Scores"
                            Margin="12"
                            Clicked="OnViewPreviousGamesChosen"
                            FontFamily="PressStartRegular">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnPointerEntered"
                                                      PointerExited="OnPointerExited" />
                        </Button.GestureRecognizers>
                    </Button>
                </Grid>
            </Grid>
        </VerticalStackLayout>
    </ContentView>

</ContentPage>