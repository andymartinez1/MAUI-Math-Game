<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    BackgroundImageSource="game.jpg"
    x:Class="MathGame.PreviousGames"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <ScrollView>
        <VerticalStackLayout Padding="200,100">
            <CollectionView x:Name="GamesList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid
                            ColumnDefinitions="*,*,*,*"
                            Padding="10"
                            RowDefinitions="50">
                            <Label
                                FontFamily="PressStartRegular"
                                FontSize="16"
                                Grid.Column="0"
                                Text="{Binding DatePlayed, StringFormat='{0:d}'}"
                                TextColor="Black" />
                            <Label
                                FontFamily="PressStartRegular"
                                FontSize="16"
                                Grid.Column="1"
                                Text="{Binding Type}"
                                TextColor="Black" />
                            <Label
                                FontFamily="PressStartRegular"
                                FontSize="16"
                                Grid.Column="2"
                                Text="{Binding Score}"
                                TextColor="Black" />
                            <Button
                                BindingContext="{Binding Id}"
                                Clicked="OnDelete"
                                FontFamily="PressStartRegular"
                                FontSize="16"
                                Grid.Column="3"
                                Text="Delete"
                                TextColor="Black">
                                <Button.GestureRecognizers>
                                    <PointerGestureRecognizer PointerEntered="OnPointerEntered" PointerExited="OnPointerExited" />
                                </Button.GestureRecognizers>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>