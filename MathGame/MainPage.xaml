<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MathGame.MainPage">

    <ContentView>
        <VerticalStackLayout Spacing="25" Padding="50">
            <Label Text="Math Game" FontSize="32" HorizontalOptions="Center" />
            <Label Text="Choose Game Mode" FontSize="24" HorizontalOptions="Center" />
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Text="Addition" Margin="12" Clicked="OnGameChosen" />
                <Button Grid.Row="0" Grid.Column="1" Text="Subtraction" Margin="12" Clicked="OnGameChosen" />
                <Button Grid.Row="0" Grid.Column="2" Text="Multiplication" Margin="12" Clicked="OnGameChosen" />
                <Button Grid.Row="0" Grid.Column="3" Text="Division" Margin="12" Clicked="OnGameChosen" />
                <Button Grid.Row="1" Grid.ColumnSpan="4" Grid.Column="0" BackgroundColor="DimGrey"
                        Text="View Previous Games"
                        Margin="12"
                        Clicked="OnViewPreviousGamesChosen" />
            </Grid>
        </VerticalStackLayout>
    </ContentView>

</ContentPage>