<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MathGame.GamePage">

    <VerticalStackLayout Padding="200" Spacing="25">
        <Label Text="{Binding GameType}" VerticalOptions="Center" HorizontalOptions="Center" />
        <Label x:Name="QuestionLabel" VerticalOptions="Center" HorizontalOptions="Center" FontSize="24" />
        <Entry x:Name="AnswerEntry" HorizontalOptions="Center" />
        <Button x:Name="SubmitAnswer" Text="Answer" HorizontalOptions="Center" Clicked="OnAnswerSubmitted" />
        <Label x:Name="AnswerLabel" VerticalOptions="Center" HorizontalOptions="Center" />
        <Label x:Name="GameOverLabel" VerticalOptions="Center" HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>